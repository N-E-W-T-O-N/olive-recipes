{
    "input_model": {
        "type": "PyTorchModel",
        "model_path": "Prince-1/OmniVoice",
        "model_loader": "get_audio_embeddings_model",
        "model_script": "user_script.py",
        "io_config": "get_audio_embeddings_io_config",
        "dummy_inputs_func": "get_audio_embeddings_dummy_inputs"
    },
    "passes": {
        "convert": {
            "type": "OnnxConversion",
            "use_dynamo_exporter": false
        },
        "ort": {
            "type": "OrtTransformersOptimization",
            "model_type": "",
            "opt_level": 1,
            "only_onnxruntime": true
        },
        "cast": {
            "type": "OnnxPeepholeOptimizer",
            "onnxscript_optimize": false,
            "onnxoptimizer_optimize": false,
            "fuse_reshape_operations": false,
            "fix_com_microsoft_opset": true,
            "cast_chain_elimination": true
        },
        "int4": {
            "type": "OnnxBlockWiseRtnQuantization",
            "block_size": 128,
            "is_symmetric": true,
            "accuracy_level": 4,
            "save_as_external_data": true,
            "external_data_name": "audio_embeddings_encoder.onnx.data"
        }
    },
    "no_artifacts": true,
    "output_dir": "cpu_and_mobile/models/audio_embeddings_encoder.onnx"
}
